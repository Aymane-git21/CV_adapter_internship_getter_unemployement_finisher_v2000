# ── CV Glowup configuration ─────────────────────────────────────────────────
# Copy to .env for local development. In production, put secrets in Google
# Secret Manager — never in tracked files (this repo learned that the hard way).

# Required
SECRET_KEY=generate-a-long-random-string
GEMINI_API_KEY=            # from https://aistudio.google.com/apikey — leave empty for offline dev (deterministic fake AI)

# Database — defaults to a local SQLite file when unset.
# Production (Neon / any Postgres): postgresql://user:pass@host/db?sslmode=require
# DATABASE_URL=

# Environment: dev | prod  (prod => Secure cookies, 0.0.0.0 binding)
ENV=dev

# Force the deterministic offline AI provider even when a key is present.
# CVG_FAKE_AI=1

# Comma-separated origins allowed to call the API from a browser.
# ALLOWED_ORIGINS=https://cvglowup.com,https://www.cvglowup.com

# Models
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL_LITE=gemini-2.5-flash-lite

# Typst binary (auto-discovered on PATH / winget; set to override)
# TYPST_BIN=

# ── Billing (Stripe) — leave empty to disable paid plans entirely ───────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PLUS=price_...
# STRIPE_PRICE_PRO=price_...
# PUBLIC_BASE_URL=https://cvglowup.com

# ── Optional integrations ───────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com   # enables "Sign in with Google"
# ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXX            # enables ads for free tier
